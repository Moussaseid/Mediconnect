# MediConnect — Variables d'environnement
# Copier en .env et remplir les valeurs réelles

# Base de données MariaDB
DB_HOST=127.0.0.1
DB_NAME=mediconnect
DB_USER=root
DB_PASS=

# JWT — générer avec : php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=REMPLACER_PAR_UNE_CLE_ALEATOIRE_64_CHARS
JWT_EXPIRES_IN=3600

# CORS — origines Angular autorisées (séparées par virgule)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# MongoDB (optionnel — logs analytiques)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=mediconnect_analytics
